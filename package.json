{
  "name": "pokemon-tcg-mcp",
  "version": "0.1.0",
  "description": "MCP server exposing Pokémon TCG card data (pokemontcg.io) and competitive meta (Limitless TCG) over stdio",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "pokemon-tcg-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "smoke": "node scripts/smoke.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.0",
    "zod": "^3.25.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
